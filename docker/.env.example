# pacsnode — environment variables
# Copy to .env and fill in real values before running docker compose up.
# Never commit .env to version control.

# ── PostgreSQL (consumed by postgres container) ───────────────────────────────
POSTGRES_DB=pacsnode
POSTGRES_USER=pacsnode
POSTGRES_PASSWORD=change_me_postgres

# ── MinIO (consumed by minio container) ───────────────────────────────────────
MINIO_ROOT_USER=pacsnode_minio
MINIO_ROOT_PASSWORD=change_me_minio

# ── Object storage (consumed by pacsnode via PACS_ prefix) ───────────────────
STORAGE_BUCKET=dicom
STORAGE_REGION=us-east-1

# ── pacsnode server (PACS_ prefix, __ separator) ─────────────────────────────
PACS_SERVER__AE_TITLE=PACSNODE
PACS_LOGGING__LEVEL=info

# Host-side port mappings (docker-compose only, not read by pacsnode)
HTTP_PORT=8042
DICOM_PORT=4242
