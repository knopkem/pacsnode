# pacsnode — Configuration Reference
#
# pacsnode loads configuration in three layers (later layers override earlier):
#   1. config.toml  — next to the executable         (optional)
#   2. config.toml  — in the current working directory (optional, overrides #1)
#   3. Environment   — PACS_ prefix, __ separator (e.g. PACS_SERVER__HTTP_PORT=9000)
#
# Copy this file to config.toml and adjust values for your deployment, or use:
#   pacsnode generate-config standalone --output config.toml
#   pacsnode generate-config production --output config.toml
# All values shown below are the defaults.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  RUNTIME PROFILE LEGEND                                                     │
# │                                                                             │
# │  [both]         — applies to both runtime profiles                          │
# │  [production]   — PostgreSQL metadata + S3-compatible blob storage          │
# │  [standalone]   — SQLite metadata + local filesystem blob storage           │
# │                                                                             │
# │  The default build includes both backend pairs and selects the active       │
# │  runtime profile from the config below. Optional slim builds still exist:   │
# │    cargo build --release --no-default-features --features production        │
# │    cargo build --release --no-default-features --features standalone        │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Server [both] ─────────────────────────────────────────────────────────────

[server]
# HTTP port for REST API and DICOMweb (STOW-RS, QIDO-RS, WADO-RS)
http_port = 8042

# DIMSE listener settings such as AE title, DICOM port, transfer syntax policy,
# and association limits are managed in the admin UI and persisted in the
# metadata store. Use the admin Nodes page to manage remote AEs instead of
# pre-seeding them here.

# ── Database [both] ───────────────────────────────────────────────────────────

[database]
# Metadata backend connection URL (REQUIRED — no default)
# postgres://...   selects the production PostgreSQL metadata backend
# sqlite://...     selects the standalone SQLite metadata backend
url = "postgres://pacsnode:secret@localhost:5432/pacsnode"

# Maximum connections in the connection pool
max_connections = 20

# Automatically run pending sqlx migrations on startup
run_migrations = true

# ── S3 Storage [production] ───────────────────────────────────────────────────
#
# Required for the production runtime profile.
# Omit this entire section in standalone mode — use [filesystem_storage] below.

[storage]
# S3-compatible object storage endpoint (REQUIRED — no default)
endpoint = "http://localhost:9000"

# S3 bucket name for DICOM pixel data (REQUIRED — no default)
bucket = "dicom"

# S3 access key ID (REQUIRED — no default)
# Prefer setting via env: PACS_STORAGE__ACCESS_KEY
access_key = ""

# S3 secret access key (REQUIRED — no default)
# Prefer setting via env: PACS_STORAGE__SECRET_KEY
secret_key = ""

# S3 region
region = "us-east-1"

# ── Filesystem Storage [standalone] ──────────────────────────────────────────
#
# Required for the standalone runtime profile.
# Remove or omit this section in production mode.
#
# [filesystem_storage]
# root = "./data/blobs"

# ── Logging [both] ────────────────────────────────────────────────────────────

[logging]
# Log level filter (tracing env_filter syntax)
# Examples: "info", "debug", "info,pacs_dimse=trace", "warn,pacs_api=debug"
level = "info"

# Log output format: "json" for structured logging, "pretty" for human-readable
format = "json"

# ── Optional Plugins [both] ─────────────────────────────────────────────────────
#
# Built-in storage and DIMSE plugins are enabled automatically for the selected
# runtime profile.
# Add optional plugin IDs below to enable them:
#   - "basic-auth"
#   - "audit-logger"
#   - "admin-dashboard"
#   - "prometheus-metrics"
#   - "ohif-viewer"

[plugins]
enabled = []

# Example local auth config:
# [plugins.basic-auth]
# mode = "local"
# jwt_secret = "replace-with-a-long-random-secret"
# access_token_ttl_secs = 900
# refresh_token_ttl_secs = 604800
# public_paths = ["/health", "/metrics"]
#
# Example external OIDC bearer-token validation:
# [plugins.basic-auth]
# mode = "oidc"
# public_paths = ["/health", "/metrics"]
#
# [plugins.basic-auth.oidc]
# issuer = "https://keycloak.example.test/realms/pacs"
# audience = "pacsnode"
#
# Standard providers can be configured with just the issuer and audience.
# pacsnode will resolve `/.well-known/openid-configuration` and discover JWKS.
#
# jwks_uri = "https://keycloak.example.test/realms/pacs/protocol/openid-connect/certs"
# jwks_refresh_secs = 300
#
# Or provide a static signing key for offline / tightly controlled deployments:
# public_key_pem = "${PACS_OIDC_PUBLIC_KEY_PEM}"
# role_claim = "realm_access.roles"
# attributes_claims = ["department", "modality_access", "email"]
# role_map = { pacs_admin = "admin", pacs_viewer = "viewer" }
#
# Set at most one of `jwks_uri` or `public_key_pem`.
# If neither is set, pacsnode uses issuer-based OIDC discovery.
#
# Bootstrap the first admin user after enabling this plugin:
#   pacsnode create-admin --username admin --email admin@example.test
#
# The command prints a one-time generated password that satisfies the persisted
# password policy. Subsequent users will be managed through the admin API/UI.
#
# When basic-auth is enabled, pacsnode auto-enables audit-logger by default for
# secured deployments unless you explicitly opt out below.
#
# Example audit logger config:
# [plugins.audit-logger]
# max_connections = 5
# auto_enable_in_secure_deployments = true
#
# Example Prometheus metrics config:
# [plugins.prometheus-metrics]
# endpoint = "/metrics"
#
# Example admin dashboard config:
# [plugins.admin-dashboard]
# route_prefix = "/admin"
# redirect_root = false
# activity_limit = 24
#
# Example OHIF/static viewer config:
# [plugins.ohif-viewer]
# static_dir = "./web/viewer"
# route_prefix = "/viewer"
# redirect_root = true
# index_file = "index.html"
# fallback_file = "index.html"
# generate_app_config = true
# provision_embedded_bundle = true
#
# By default, pacsnode extracts its embedded OHIF bundle into `./web/viewer`
# on first start when the directory is missing or empty.
#
# If basic-auth and ohif-viewer are both enabled, add "/" and "/viewer" to
# [plugins.basic-auth].public_paths so the viewer shell can load before it makes
# authenticated API requests. The viewer's API calls still require login.
